{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10
  },
  "service": {
    "name": "eni-cnc",
    "port": 8080,
    "protocol": "tcp",
    "volumes": [
      {
        "name": "eni-data",
        "path": "/data"
      }
    ]
  }
}
